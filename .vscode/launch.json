{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tests/test_message_dispatcher.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [],
            "cwd": "${workspaceFolder}", // <--- important
